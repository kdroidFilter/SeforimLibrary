-- Source queries

selectAll:
SELECT * FROM source ORDER BY name;

selectById:
SELECT * FROM source WHERE id = ?;

selectByName:
SELECT * FROM source WHERE name = ? LIMIT 1;

insert:
INSERT INTO source (name) VALUES (?);

insertWithId:
INSERT OR IGNORE INTO source (id, name) VALUES (?, ?);

lastInsertRowId:
SELECT last_insert_rowid();

